{
  "name": "@codespar/cli",
  "version": "0.5.5",
  "description": "CodeSpar CLI. The agentic OS for money movement in Latin America, from your terminal: authenticate, browse servers, mint mandates, execute tools, manage sessions, stream logs.",
  "type": "module",
  "bin": {
    "codespar": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "codespar",
    "ai-agent",
    "commerce",
    "mcp",
    "pix",
    "latam"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/codespar-core",
    "directory": "packages/cli"
  },
  "homepage": "https://codespar.dev/docs/cli",
  "bugs": {
    "url": "https://github.com/codespar/codespar-core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@codespar/sdk": "^0.10.1",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  }
}

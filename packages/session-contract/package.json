{
  "name": "@codespar/session-contract",
  "version": "0.1.0",
  "description": "Shared session interface contract for codespar runtimes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "development": {
        "import": "./dist/testing/contract-suite.js",
        "types": "./dist/testing/contract-suite.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codespar",
    "session",
    "contract",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/codespar-core",
    "directory": "packages/session-contract"
  },
  "homepage": "https://codespar.dev",
  "bugs": {
    "url": "https://github.com/codespar/codespar-core/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

{
  "name": "@codespar/autogen",
  "version": "0.2.0",
  "description": "Microsoft AutoGen adapter for CodeSpar — convert session tools to AutoGen function tool format",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["codespar", "autogen", "microsoft", "tools", "adapter", "multi-agent"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/codespar-core",
    "directory": "packages/autogen"
  },
  "peerDependencies": {
    "@codespar/sdk": "^0.2.0"
  },
  "devDependencies": {
    "@codespar/sdk": "0.2.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

{
  "name": "@codespar/vercel",
  "version": "0.2.0",
  "description": "Vercel AI SDK adapter for CodeSpar — convert MCP tools to Vercel AI tool format",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codespar",
    "vercel-ai",
    "ai-sdk",
    "adapter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/codespar-core",
    "directory": "packages/vercel"
  },
  "peerDependencies": {
    "@codespar/sdk": "^0.2.0",
    "ai": ">=3.0.0"
  },
  "devDependencies": {
    "@codespar/sdk": "0.2.2",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

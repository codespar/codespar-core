{
  "name": "@codespar/letta",
  "version": "0.3.0",
  "description": "Letta (MemGPT) adapter for CodeSpar — convert session tools to Letta tool format",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codespar",
    "letta",
    "memgpt",
    "tools",
    "adapter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/codespar-core",
    "directory": "packages/letta"
  },
  "peerDependencies": {
    "@codespar/sdk": "^0.3.0"
  },
  "devDependencies": {
    "@codespar/sdk": "*",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codespar",
    "claude",
    "anthropic",
    "agent-sdk",
    "adapter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/codespar-core",
    "directory": "packages/claude"
  },
  "peerDependencies": {
    "@codespar/sdk": "^0.2.0"
  },
  "devDependencies": {
    "@codespar/sdk": "0.2.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

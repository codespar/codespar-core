{
  "name": "@codespar/hermes",
  "version": "0.4.1",
  "description": "Hermes Agent adapter for CodeSpar — convert session tools to Hermes MCP/plugin tool format",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codespar",
    "hermes",
    "nous",
    "mcp",
    "tools",
    "adapter",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codespar/codespar-core",
    "directory": "packages/hermes"
  },
  "peerDependencies": {
    "@codespar/sdk": "^0.10.0 || ^0.11.0"
  },
  "devDependencies": {
    "@codespar/sdk": "*",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

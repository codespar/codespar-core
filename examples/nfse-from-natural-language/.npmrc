# @copilotkit/aimock declares vitest>=3 as a peerOptional dep; this
# example pins vitest@^2 to match the rest of the examples tree. The
# peer is *optional* (aimock works fine with vitest 2 — the plugin
# integration is the only feature that needs 3+, and we don't use
# it). Tell npm to install anyway instead of failing the lock-resolve.
legacy-peer-deps=true
